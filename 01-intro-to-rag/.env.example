# Copy this file to .env and fill in your keys.
# .env is gitignored. Never commit real keys.

# --- Pinecone ---
# Get a free key from https://app.pinecone.io/ (Settings → API Keys)
PINECONE_API_KEY=pcsk_your_key_here

# Where your serverless indexes live. aws / us-east-1 is the free-tier default.
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Default index name used by the notebooks. Change it if you want to keep
# multiple learning runs side-by-side.
PINECONE_INDEX_NAME=rag-unpacked-intro

# --- OpenAI ---
# Get a key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_key_here

# Embedding + chat models used by NB3. Swap freely.
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
